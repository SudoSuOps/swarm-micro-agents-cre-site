# SwarmCore site — environment variables
# Copy to .env.local and fill in your values.

# Base URL for the sovereign backend API.
# All API calls (/api/health, /api/assets, /api/runs, /api/contact) are prefixed with this.
# Leave empty to use same-origin (default when the backend is behind the same nginx host).
VITE_API_BASE_URL=

# Resend API key — required for contact form email delivery.
# Set this in Cloudflare Pages → Settings → Environment Variables (do NOT commit the real key).
# The swarmandbee.ai domain must be verified in your Resend account.
RESEND_API_KEY=
